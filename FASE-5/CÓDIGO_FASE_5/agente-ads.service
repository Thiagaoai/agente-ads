[Unit]
Description=Agente-Ads · Meta Ads + Google Ads autonomous agents
Documentation=https://github.com/Thiagaoai/agente-ads
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=agente-ads
Group=agente-ads
WorkingDirectory=/opt/agente-ads/FASE-5/CÓDIGO_FASE_5
EnvironmentFile=/opt/agente-ads/FASE-5/CÓDIGO_FASE_5/.env
ExecStart=/usr/bin/node index.js

Restart=on-failure
RestartSec=10s
StartLimitBurst=5
StartLimitIntervalSec=300

StandardOutput=journal
StandardError=journal
SyslogIdentifier=agente-ads

NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/log/agente-ads

LimitNOFILE=65536
MemoryMax=1G
CPUQuota=80%

[Install]
WantedBy=multi-user.target
