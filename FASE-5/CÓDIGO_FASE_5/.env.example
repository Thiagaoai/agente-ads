# ============================================================
# Marketing Squad — Phase 5 · Environment Variables
# Copy to .env and fill ALL values before running.
# ============================================================

# --- Runtime --------------------------------------------------
NODE_ENV=production
DEBUG=false
LOG_LEVEL=info
CMO_PORT=3200
PAPERCLIP_PORT=3100

# --- Supabase (create one project per client) -----------------
# https://supabase.com/dashboard → New project
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- OpenAI (GPT-4o + DALL-E 3) -------------------------------
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxx

# --- Meta Ads API v19 -----------------------------------------
# 1) Create System User: https://business.facebook.com/settings/system-users
# 2) Generate token with ads_management + ads_read scopes
# 3) Ad Account ID format: act_1234567890
# 4) Pixel: https://business.facebook.com/events_manager
META_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxx
META_AD_ACCOUNT_ID=act_1234567890
META_PIXEL_ID=1234567890123456

# --- Google Ads API -------------------------------------------
# 1) Developer Token: https://ads.google.com/aw/apicenter
# 2) OAuth2 client: https://console.cloud.google.com/apis/credentials
# 3) Refresh token via oauth2l or https://developers.google.com/oauthplayground
GOOGLE_ADS_CUSTOMER_ID=1234567890
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# --- Runway ML (video generation) -----------------------------
# https://app.runwayml.com/account (Enterprise plan for gen3 API)
RUNWAY_API_KEY=

# --- SEMrush (SEO + competitor tracking) ----------------------
# https://www.semrush.com/api-documentation/
SEMRUSH_API_KEY=

# --- Cloudinary (content storage) -----------------------------
# https://console.cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Telegram (operator control + alerts) ---------------------
# Bot: t.me/BotFather → /newbot
# Operator ID: t.me/userinfobot
# Channel: add bot as admin, forward msg to @getidsbot
TELEGRAM_BOT_TOKEN=1234567890:ABCxxxxxxxxxxxxxxxxxxx
TELEGRAM_OPERATOR_ID=123456789
TELEGRAM_CHANNEL_ID=-1001234567890

# --- Client scoping (multi-tenant) ----------------------------
# Identifier for this deployment (lowercase, no spaces)
CLIENT_ID=acme-corp
CLIENT_NAME=Acme Corp
CLIENT_DOMAIN=acme.com
